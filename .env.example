# Flask Configuration
FLASK_SECRET_KEY=your-random-secret-key-here
DATABASE_URL=sqlite:///foodchain_ai.db
FLASK_ENV=production

# API URL (Render backend)
VITE_API_URL=https://foodchainai.onrender.com

# Frontend URL (for Vercel deployment)
FRONTEND_URL=https://your-project.vercel.app

# Email Service (for OTP - optional)
EMAIL_SERVICE_KEY=your-email-service-key
EMAIL_FROM=noreply@foodchainai.com
